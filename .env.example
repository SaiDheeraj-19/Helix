################################################################################
# HELIX - Environment Configuration
################################################################################

APP_NAME=HELIX
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

################################################################################
# Database
################################################################################

POSTGRES_HOST=helix-postgres
POSTGRES_PORT=5432
POSTGRES_DB=helix
POSTGRES_USER=helix
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql+psycopg://helix:change_me@helix-postgres:5432/helix

################################################################################
# Cache
################################################################################

VALKEY_HOST=helix-valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=

REDIS_URL=redis://helix-valkey:6379

################################################################################
# Message Queue
################################################################################

NATS_HOST=helix-nats
NATS_PORT=4222

# Optional
RABBITMQ_HOST=helix-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=helix
RABBITMQ_PASSWORD=change_me

################################################################################
# Object Storage
################################################################################

MINIO_ENDPOINT=http://helix-minio:9000

MINIO_ROOT_USER=helix

MINIO_ROOT_PASSWORD=change_me

MINIO_BUCKET=uploads

MINIO_USE_SSL=false

################################################################################
# Search
################################################################################

MEILISEARCH_URL=http://meilisearch:7700

MEILISEARCH_MASTER_KEY=change_me

################################################################################
# Vector Database
################################################################################

QDRANT_URL=http://qdrant:6333

################################################################################
# Knowledge Graph
################################################################################

MEMGRAPH_HOST=memgraph

MEMGRAPH_PORT=7687

################################################################################
# Authentication
################################################################################

JWT_SECRET=replace_with_long_secret

JWT_ALGORITHM=HS256

JWT_EXPIRE_MINUTES=1440

AUTH_PROVIDER=internal

################################################################################
# AI Gateway
################################################################################

AI_PROVIDER=ollama

AI_FALLBACK_PROVIDER=openai

################################################################################
# Ollama
################################################################################

OLLAMA_BASE_URL=http://ollama:11434

OLLAMA_DEFAULT_MODEL=qwen3

################################################################################
# OpenAI
################################################################################

OPENAI_API_KEY=

################################################################################
# Gemini
################################################################################

GEMINI_API_KEY=

################################################################################
# Groq
################################################################################

GROQ_API_KEY=

################################################################################
# OpenRouter
################################################################################

OPENROUTER_API_KEY=

################################################################################
# Observability
################################################################################

PROMETHEUS_ENABLED=true

GRAFANA_ENABLED=true

################################################################################
# Email
################################################################################

SMTP_HOST=

SMTP_PORT=587

SMTP_USER=

SMTP_PASSWORD=

SMTP_FROM=noreply@helix.local

################################################################################
# Notifications
################################################################################

NOVU_API_KEY=

################################################################################
# Uploads
################################################################################

MAX_UPLOAD_SIZE_MB=100

################################################################################
# Security
################################################################################

RATE_LIMIT=100/minute

CORS_ALLOWED_ORIGINS=http://localhost:3000

################################################################################
# Logging
################################################################################

LOG_LEVEL=INFO

################################################################################
# Docker
################################################################################

DOCKERIZED=true

################################################################################
# Feature Flags
################################################################################

ENABLE_AI=true

ENABLE_GRAPH=true

ENABLE_ANALYTICS=true

ENABLE_REALTIME=true

ENABLE_NOTIFICATIONS=true

################################################################################
# Frontend
################################################################################

NEXT_PUBLIC_API_URL=http://localhost:8000

NEXT_PUBLIC_APP_NAME=HELIX

NEXT_PUBLIC_ENABLE_AI=true

################################################################################
# Realtime
################################################################################

WEBSOCKET_URL=ws://localhost:8000/ws
